  <!-- ════════════════════════════════════════
       MAIN JAVASCRIPT
       Lenis smooth scroll, tema según sistema,
       Intersection Observer, parallax, counters,
       canvas grid, navbar scroll, menu mobile,
       ripple effect, active section indicator
       ════════════════════════════════════════ -->
  <script>
    // @ts-nocheck
    import Lenis from 'lenis';
    import emailjs from '@emailjs/browser';

    /* ─── HELPERS ─── */
    const $ = (sel, ctx) => (ctx || document).querySelector(sel);
    const $$ = (sel, ctx) => [...(ctx || document).querySelectorAll(sel)];
    const html = document.documentElement;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ─── 1. LENIS — Premium smooth scroll ─── */
    let lenis;

    function initLenis() {
      if (prefersReducedMotion) return;

      lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        orientation: 'vertical',
        gestureOrientation: 'vertical',
        smoothWheel: true,
        touchMultiplier: 1.5,
      });

      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);
    }

    /* ─── 2. TEMA — Solo preferencia del sistema (sin toggle ni localStorage) ─── */
    function initSystemTheme() {
      const mq = window.matchMedia('(prefers-color-scheme: dark)');

      function applyFromSystem(withTransition) {
        const theme = mq.matches ? 'dark' : 'light';
        if (withTransition) {
          html.classList.add('theme-transitioning');
          setTimeout(() => html.classList.remove('theme-transitioning'), 450);
        }
        html.setAttribute('data-theme', theme);
      }

      applyFromSystem(false);
      mq.addEventListener('change', () => applyFromSystem(true));
    }

    /* ─── 3. HERO CANVAS — Animated dot grid (theme-aware) ─── */
    function initHeroCanvas() {
      const canvas = $('#hero-canvas');
      if (!canvas || prefersReducedMotion) return;
      const ctx = canvas.getContext('2d');
      let w, h, cols, rows, dots;
      const SPACING = 45;
      const DOT_RADIUS = 1.2;
      let mouseX = -1000, mouseY = -1000;
      const INFLUENCE = 120;
      let animId;

      function getAccentRGB() {
        const heroRgb = getComputedStyle(html).getPropertyValue('--hero-canvas-rgb').trim();
        return heroRgb || getComputedStyle(html).getPropertyValue('--accent-rgb').trim();
      }

      function getDotAlpha() {
        return parseFloat(getComputedStyle(html).getPropertyValue('--hero-dot-alpha').trim()) || 0.1;
      }

      function resize() {
        const rect = canvas.parentElement.getBoundingClientRect();
        w = canvas.width = rect.width;
        h = canvas.height = rect.height;
        cols = Math.ceil(w / SPACING) + 1;
        rows = Math.ceil(h / SPACING) + 1;
        dots = [];
        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < cols; c++) {
            dots.push({ x: c * SPACING, y: r * SPACING, ox: c * SPACING, oy: r * SPACING });
          }
        }
      }

      function draw() {
        ctx.clearRect(0, 0, w, h);
        const rgb = getAccentRGB();
        const baseAlpha = getDotAlpha();
        for (const dot of dots) {
          const dx = mouseX - dot.ox;
          const dy = mouseY - dot.oy;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < INFLUENCE) {
            const force = (1 - dist / INFLUENCE) * 12;
            dot.x = dot.ox + (dx / dist) * force;
            dot.y = dot.oy + (dy / dist) * force;
          } else {
            dot.x += (dot.ox - dot.x) * 0.08;
            dot.y += (dot.oy - dot.y) * 0.08;
          }
          const alpha = dist < INFLUENCE
            ? baseAlpha + (1 - dist / INFLUENCE) * 0.5
            : baseAlpha;
          ctx.beginPath();
          ctx.arc(dot.x, dot.y, DOT_RADIUS, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${rgb}, ${alpha})`;
          ctx.fill();
        }
        animId = requestAnimationFrame(draw);
      }

      canvas.parentElement.addEventListener('mousemove', (e) => {
        const rect = canvas.getBoundingClientRect();
        mouseX = e.clientX - rect.left;
        mouseY = e.clientY - rect.top;
      }, { passive: true });

      canvas.parentElement.addEventListener('mouseleave', () => {
        mouseX = -1000;
        mouseY = -1000;
      }, { passive: true });

      window.addEventListener('resize', () => {
        cancelAnimationFrame(animId);
        resize();
        draw();
      }, { passive: true });

      resize();
      draw();
    }

    /* ─── 4. NAVBAR — scroll glass effect + active section indicator ─── */
    function initNavbar() {
      const header = $('#site-header');
      const sections = $$('.target-section');
      const navLinks = $$('.s-header__menu-links a');

      if (!header) return;

      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            if (window.scrollY > 60) {
              header.classList.add('is-scrolled');
            } else {
              header.classList.remove('is-scrolled');
            }

            let current = '';
            for (const section of sections) {
              const rect = section.getBoundingClientRect();
              if (rect.top <= 150 && rect.bottom > 150) {
                current = '#' + section.id;
                break;
              }
            }
            if (current) {
              navLinks.forEach((link) => {
                const li = link.closest('li');
                if (li) {
                  li.classList.toggle('current', link.getAttribute('href') === current);
                }
              });
            }
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    }

    /* ─── 5. MOBILE MENU ─── */
    function initMobileMenu() {
      const nav = $('#site-nav');
      const toggle = $('.s-header__menu-toggle');
      const overlay = $('#nav-overlay');
      const menuLinks = $$('.s-header__menu-links a');

      if (!toggle || !nav) return;

      function setMenuOpen(open) {
        nav.classList.toggle('is-open', open);
        toggle.classList.toggle('is-clicked', open);
        toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
        if (overlay) overlay.classList.toggle('is-visible', open);
        document.body.style.overflow = open ? 'hidden' : '';
        /* Pause/resume Lenis when mobile menu is open */
        if (lenis) {
          open ? lenis.stop() : lenis.start();
        }
      }

      toggle.addEventListener('click', () => {
        setMenuOpen(!nav.classList.contains('is-open'));
      });

      if (overlay) {
        overlay.addEventListener('click', () => setMenuOpen(false));
      }

      menuLinks.forEach((link) => {
        link.addEventListener('click', () => {
          if (window.matchMedia('(max-width: 1100px)').matches) {
            setMenuOpen(false);
          }
        });
      });
    }

    /* ─── 6. SMOOTH SCROLL — powered by Lenis with navbar offset ─── */
    function initSmoothScroll() {
      const headerH = () => parseFloat(getComputedStyle(html).getPropertyValue('--header-h')) * 10;

      $$("a.smoothscroll[href^='#']").forEach((anchor) => {
        anchor.addEventListener('click', (e) => {
          const id = anchor.getAttribute('href');
          if (!id || id === '#') return;
          const el = $(id);
          if (!el) return;
          e.preventDefault();

          if (lenis) {
            /* Lenis provides smooth, momentum-based scroll */
            lenis.scrollTo(el, {
              offset: -(headerH() + 10),
              duration: 1.4,
              easing: (t) => 1 - Math.pow(1 - t, 4),
            });
          } else {
            /* Fallback for reduced-motion or no Lenis */
            const top = el.getBoundingClientRect().top + window.scrollY - headerH() - 10;
            window.scrollTo({ top, behavior: 'smooth' });
          }
        });
      });
    }

    /* ─── 7. SCROLL REVEAL — Intersection Observer with stagger ─── */
    function initScrollReveal() {
      const revealEls = $$('.reveal, .reveal--left, .reveal--right, .reveal--scale, .reveal--fade, .reveal-scale');

      if (prefersReducedMotion) {
        revealEls.forEach((el) => el.classList.add('is-visible'));
        return;
      }

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -60px 0px' }
      );

      revealEls.forEach((el) => observer.observe(el));
    }

    /* ─── 8. ANIMATED COUNTERS ─── */
    function initCounters() {
      const counters = $$('[data-count]');
      if (!counters.length) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target;
              const target = parseInt(el.getAttribute('data-count'), 10);
              const duration = 1800;
              const start = performance.now();

              function update(now) {
                const elapsed = now - start;
                const progress = Math.min(elapsed / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                const current = Math.round(eased * target);
                el.textContent = '+' + current;
                if (progress < 1) {
                  requestAnimationFrame(update);
                }
              }

              if (prefersReducedMotion) {
                el.textContent = '+' + target;
              } else {
                requestAnimationFrame(update);
              }
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.5 }
      );

      counters.forEach((c) => observer.observe(c));
    }

    /* ─── 9. PARALLAX — Hero image follows mouse ─── */
    function initParallax() {
      const figure = $('#hero-figure');
      if (!figure || prefersReducedMotion) return;

      const introSection = $('.s-intro');
      if (!introSection) return;

      introSection.addEventListener('mousemove', (e) => {
        const rect = introSection.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        figure.style.transform = `translate(${x * -12}px, ${y * -8}px) rotateY(${x * 2}deg) rotateX(${-y * 2}deg)`;
      }, { passive: true });

      introSection.addEventListener('mouseleave', () => {
        figure.style.transform = 'translate(0, 0) rotateY(0) rotateX(0)';
      }, { passive: true });
    }

    /* ─── 10. 3D TILT — Service cards ─── */
    function initCardTilt() {
      if (prefersReducedMotion) return;

      $$('[data-tilt]').forEach((card) => {
        card.addEventListener('mousemove', (e) => {
          const rect = card.getBoundingClientRect();
          const x = (e.clientX - rect.left) / rect.width - 0.5;
          const y = (e.clientY - rect.top) / rect.height - 0.5;
          card.style.transform = `translateY(-4px) perspective(800px) rotateX(${-y * 6}deg) rotateY(${x * 6}deg)`;
        }, { passive: true });

        card.addEventListener('mouseleave', () => {
          card.style.transform = '';
        }, { passive: true });
      });
    }

    /* ─── 11. RIPPLE EFFECT — on primary buttons ─── */
    function initRipple() {
      $$('.btn--primary').forEach((btn) => {
        btn.addEventListener('click', function (e) {
          const ripple = document.createElement('span');
          ripple.classList.add('ripple');
          const rect = btn.getBoundingClientRect();
          const size = Math.max(rect.width, rect.height);
          ripple.style.width = ripple.style.height = size + 'px';
          ripple.style.left = e.clientX - rect.left - size / 2 + 'px';
          ripple.style.top = e.clientY - rect.top - size / 2 + 'px';
          btn.appendChild(ripple);
          ripple.addEventListener('animationend', () => ripple.remove());
        });
      });
    }

    /* ─── 12. GO-TOP BUTTON ─── */
    function initGoTop() {
      const goTop = $('#go-top');
      if (!goTop) return;
      window.addEventListener('scroll', () => {
        goTop.classList.toggle('is-visible', window.scrollY > 600);
      }, { passive: true });
    }

    /* ─── 13. CONTACT FORM — EmailJS ─── */
    const EMAILJS_CONFIG = {
      serviceId:       'service_8jn6y5r',
      templateId:      'template_s4fyv79',      // notificación interna
      templateReplyId: 'template_uqont8f',      // auto-reply al cliente
      publicKey:       'cl53ezM2SDAFK6NOz',
    };

    const validators = {
      user_name: v => {
        if (!v.trim())           return 'El nombre es obligatorio';
        if (v.trim().length < 2) return 'Mínimo 2 caracteres';
        return null;
      },
      user_email: v => {
        if (!v.trim())                              return 'El correo es obligatorio';
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v)) return 'Correo inválido';
        return null;
      },
      service_interest: v => {
        if (!v) return 'Selecciona un servicio';
        return null;
      },
      message: v => {
        if (!v.trim())            return 'El mensaje es obligatorio';
        if (v.trim().length < 10) return 'Mínimo 10 caracteres';
        return null;
      },
    };

    function initForm() {
      const form = $('#contactForm');
      if (!form) return;

      emailjs.init({ publicKey: EMAILJS_CONFIG.publicKey });

      const submitBtn  = $('#submitBtn');
      const btnText    = submitBtn?.querySelector('.btn-text');
      const btnLoader  = submitBtn?.querySelector('.btn-loader');
      const btnDone    = submitBtn?.querySelector('.btn-success-text');
      const formStatus = $('#formStatus');

      function showFieldError(name, msg) {
        const err = document.getElementById('error-' + name);
        const inp = form.querySelector('[name="' + name + '"]');
        if (err) err.textContent = msg || '';
        if (inp) {
          inp.classList.toggle('input-error', !!msg);
          inp.classList.toggle('input-valid', !msg && inp.value.trim() !== '');
        }
      }

      // Real-time validation
      form.querySelectorAll('input, select, textarea').forEach(el => {
        el.addEventListener('blur', () => {
          const err = validators[el.name]?.(el.value);
          showFieldError(el.name, err);
        });
        el.addEventListener('input', () => {
          if (el.classList.contains('input-error')) {
            const err = validators[el.name]?.(el.value);
            if (!err) showFieldError(el.name, null);
          }
        });
      });

      function validateAll() {
        let valid = true;
        Object.keys(validators).forEach(name => {
          const el  = form.querySelector('[name="' + name + '"]');
          const err = el ? validators[name](el.value) : null;
          showFieldError(name, err);
          if (err) valid = false;
        });
        return valid;
      }

      function setBtn(state) {
        if (!submitBtn) return;
        const busy = state === 'loading' || state === 'success';
        submitBtn.disabled = busy;
        submitBtn.setAttribute('aria-busy', state === 'loading' ? 'true' : 'false');
        const showLabel = state === 'idle' || state === 'error';
        if (btnText) btnText.hidden = !showLabel;
        if (btnLoader) btnLoader.hidden = state !== 'loading';
        if (btnDone) btnDone.hidden = state !== 'success';
        submitBtn.dataset.state = state;
      }

      setBtn('idle');

      function showStatus(type, msg) {
        if (!formStatus) return;
        formStatus.textContent = msg;
        formStatus.className = 'form-status form-status--' + type + ' visible';
        setTimeout(() => formStatus.classList.remove('visible'), 8000);
      }

      function isBot() {
        return form.querySelector('[name="bot_field"]')?.value !== '';
      }

      form.addEventListener('submit', async e => {
        e.preventDefault();
        if (isBot()) return;

        if (!validateAll()) {
          const firstErr = form.querySelector('.input-error');
          firstErr?.scrollIntoView({ behavior: 'smooth', block: 'center' });
          firstErr?.focus();
          return;
        }

        setBtn('loading');

        try {
          // Envío paralelo: notificación interna + auto-reply al cliente
          const [res1, res2] = await Promise.all([
            // 1. Notificación interna — llega a Pymatica Chile
            emailjs.sendForm(
              EMAILJS_CONFIG.serviceId,
              EMAILJS_CONFIG.templateId,
              form
            ),
            // 2. Auto-reply — llega al cliente automáticamente
            emailjs.send(
              EMAILJS_CONFIG.serviceId,
              EMAILJS_CONFIG.templateReplyId,
              {
                user_name:        form.querySelector('[name="user_name"]').value,
                user_email:       form.querySelector('[name="user_email"]').value,
                user_phone:       form.querySelector('[name="user_phone"]').value,
                user_company:     form.querySelector('[name="user_company"]').value,
                service_interest: form.querySelector('[name="service_interest"]').value,
                message:          form.querySelector('[name="message"]').value,
              }
            )
          ]);
          console.log('Notificación enviada:', res1.status, res1.text);
          console.log('Auto-reply enviado:',  res2.status, res2.text);
          setBtn('success');
          showStatus('success', '✅ ¡Mensaje enviado! Te contactaremos pronto.');

          setTimeout(() => {
            form.reset();
            form.querySelectorAll('.input-valid,.input-error').forEach(el => {
              el.classList.remove('input-valid', 'input-error');
            });
            setBtn('idle');
          }, 3000);
        } catch (err) {
          console.error('Error en envío EmailJS:', {
            status:  err.status,
            text:    err.text,
            message: err.message
          });
          setBtn('error');

          let msg = '❌ Error al enviar. Intenta nuevamente.';
          if (err.status === 400)  msg = '❌ Error de configuración. Contacta al admin.';
          if (err.status === 429)  msg = '⏳ Demasiados intentos. Espera unos minutos.';
          if (!navigator.onLine)   msg = '📡 Sin conexión a internet.';

          showStatus('error', msg);
          setTimeout(() => setBtn('idle'), 5000);
        }
      });
    }

    /* ─── 14. ODOO MODULES — <dialog> + JSON en #odoo-modules-json ─── */
    function initOdooModals() {
      const dataEl = document.getElementById('odoo-modules-json');
      const dialog = document.getElementById('odoo-module-dialog');
      if (!dataEl || !dialog) return;

      let modules;
      try {
        modules = JSON.parse(dataEl.textContent || '[]');
      } catch {
        return;
      }

      const titleEl = dialog.querySelector('#odoo-modal-title');
      const bodyEl = dialog.querySelector('.odoo-modal__body');
      const iconEl = dialog.querySelector('.odoo-modal__icon');
      const closeBtn = dialog.querySelector('.odoo-modal__close');
      if (!titleEl || !bodyEl || !iconEl || !closeBtn) return;

      function openModule(mod) {
        titleEl.textContent = mod.title;
        bodyEl.textContent = '';
        const p = document.createElement('p');
        p.textContent = mod.body;
        bodyEl.appendChild(p);
        iconEl.src = mod.icon;
        iconEl.alt = '';
        iconEl.removeAttribute('hidden');
        dialog.showModal();
      }

      function closeModal() {
        dialog.close();
      }

      $$('.about-odoo__tile').forEach((btn) => {
        btn.addEventListener('click', () => {
          const id = btn.getAttribute('data-module');
          const mod = modules.find((m) => m.id === id);
          if (mod) openModule(mod);
        });
      });

      closeBtn.addEventListener('click', closeModal);
      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) closeModal();
      });
    }

    /* ─── INIT ALL ─── */
    initLenis();
    initSystemTheme();
    initHeroCanvas();
    initNavbar();
    initMobileMenu();
    initSmoothScroll();
    initScrollReveal();
    initCounters();
    initParallax();
    initCardTilt();
    initRipple();
    initGoTop();
    initForm();
    initOdooModals();
  </script>
</Layout>
