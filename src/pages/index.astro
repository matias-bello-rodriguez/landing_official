---
import Layout from "../layouts/Layout.astro";

const title =
  "Pymatica — Desarrollo de software, automatización e integración para pymes | Biobío, Chile";
const year = new Date().getFullYear();
---

<Layout title={title}>
  <a class="skip-link" href="#content">Saltar al contenido</a>

  <div class="s-pagewrap">
    <header class="s-header">
      <div class="s-header__inner">
        <a class="s-header__brand smoothscroll" href="#intro">Pymatica<span>.</span></a>
        <button
          type="button"
          class="s-header__menu-toggle"
          aria-expanded="false"
          aria-controls="site-nav"
          aria-label="Abrir menú"
        >
          <span></span>
        </button>
        <nav id="site-nav" class="s-header__nav" aria-label="Principal">
          <ul class="s-header__menu-links">
            <li class="current"><a href="#intro" class="smoothscroll">Introducción</a></li>
            <li><a href="#about" class="smoothscroll">Enfoque</a></li>
            <li><a href="#services" class="smoothscroll">Servicios</a></li>
            <li><a href="#folio" class="smoothscroll">Casos</a></li>
            <li><a href="#beneficios" class="smoothscroll">Beneficios</a></li>
            <li><a href="#proceso" class="smoothscroll">Proceso</a></li>
            <li><a href="#footer" class="smoothscroll">Contacto</a></li>
          </ul>
          <ul class="s-header__social">
            <li>
              <a href="https://www.linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24" aria-hidden="true"
                  ><path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  ></path></svg
                >
                <span class="u-screen-reader-text">LinkedIn</span>
              </a>
            </li>
            <li>
              <a href="https://github.com" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                <svg viewBox="0 0 24 24" aria-hidden="true"
                  ><path
                    d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                  ></path></svg
                >
                <span class="u-screen-reader-text">GitHub</span>
              </a>
            </li>
          </ul>
          <a class="s-header__menu-button smoothscroll" href="#footer">Agendar</a>
        </nav>
      </div>
    </header>

    <section id="content" class="s-content">
      <section id="intro" class="s-intro target-section">
        <div
          class="s-intro__bg"
          role="img"
          aria-label="Desarrollador escribiendo código en un MacBook"
        ></div>
        <div class="s-intro__content">
          <div class="s-intro__content-inner">
            <h1 class="s-intro__content-title">
              Automatizamos los procesos<br /> de tu empresa
            </h1>
            <p class="s-intro__lead">
              Software a medida, integración de sistemas y arquitectura de la información para pymes
              industriales en la Región del Biobío: celulosa, logística, construcción, aserraderos y minería.
            </p>
            <div class="s-intro__content-buttons">
              <a class="btn btn--primary smoothscroll" href="#footer">Solicitar diagnóstico</a>
              <a class="btn btn--stroke smoothscroll" href="#services">Ver soluciones</a>
              <a
                class="s-intro__content-video-btn smoothscroll"
                href="#services"
                aria-label="Ir a soluciones"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                  ><path d="M7 6v12l10-6z"></path></svg
                >
              </a>
            </div>
          </div>
        </div>
        <div class="s-intro__scroll-down">
          <a href="#about" class="smoothscroll"><span>Desplazarse hacia abajo</span></a>
        </div>
      </section>

      <section id="about" class="s-about target-section">
        <div class="section-header" data-num="01">
          <h3 class="section-header__pretitle">Problema y solución</h3>
          <div class="section-header__grid">
            <h2 class="text-display-1">
              Cuando Excel, el papel y los sistemas viejos no alcanzan.
            </h2>
            <p class="desc">
              Las pymes industriales pierden horas en tareas repetitivas, duplican datos y deciden a ciegas.
              Nosotros ordenamos la información, conectamos lo que ya tienes y automatizamos lo que frena tu
              operación.
            </p>
          </div>
        </div>
        <div class="ps-grid">
          <div class="ps-card">
            <h3>Lo que duele hoy</h3>
            <ul class="ps-list">
              <li>Procesos manuales y lentos</li>
              <li>Excel desordenado y versiones distintas</li>
              <li>Sistemas desconectados (ERP, bodega, contabilidad)</li>
              <li>Pérdida de tiempo y errores costosos</li>
            </ul>
          </div>
          <div class="ps-card ps-card--solution">
            <h3>Cómo lo resolvemos</h3>
            <ul class="ps-list">
              <li>Automatización de flujos y alertas</li>
              <li>Integración entre plataformas y APIs</li>
              <li>Software centralizado y trazable</li>
              <li>Menos fricción, más control operativo</li>
            </ul>
          </div>
        </div>
        <div class="about-visual">
          <img
            src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?auto=format&fit=crop&w=1600&q=80"
            alt="Equipo de una pyme colaborando y revisando el trabajo juntos"
            width="1600"
            height="900"
            loading="lazy"
          />
        </div>
      </section>

      <section id="services" class="s-services target-section">
        <div class="section-header" data-num="02">
          <h3 class="section-header__pretitle">Qué hacemos</h3>
          <div class="section-header__grid">
            <h2 class="text-display-1">Cuatro pilares para transformar tu operación.</h2>
            <p class="desc">
              Trabajamos con un lenguaje claro, sin tecnicismos innecesarios. Cada proyecto apunta a resultados
              medibles: tiempo recuperado, errores evitados y decisiones con datos confiables.
            </p>
          </div>
        </div>
        <div class="services-list">
          <article class="list-block__item">
            <div class="list-block__title">
              <div class="list-block__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                  ><path
                    d="M12 2L4 5v6.09c0 5.05 3.41 9.76 8 10.91 4.59-1.15 8-5.86 8-10.91V5l-8-3zm6 9c0 4.52-2.98 8.69-7 9.93-4.02-1.24-7-5.41-7-9.93V6.3l7-2.11 7 2.11V11zm-9.5-2L12 11l3.5-2L12 7 8.5 9z"
                  ></path></svg
                >
              </div>
              <h3 class="h5">Automatización de procesos</h3>
            </div>
            <div class="list-block__text">
              <p>
                Flujos automáticos entre áreas: aprobaciones, notificaciones, cargas de datos
                recurrentes. Menos tareas manuales, más consistencia en planta y oficina.
              </p>
              <div class="list-block__tags">
                <span class="tag">Flujos automáticos</span>
                <span class="tag">Menos tareas manuales</span>
              </div>
            </div>
          </article>
          <article class="list-block__item">
            <div class="list-block__title">
              <div class="list-block__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                  ><path
                    d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0L19.2 12l-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"
                  ></path></svg
                >
              </div>
              <h3 class="h5">Desarrollo de software</h3>
            </div>
            <div class="list-block__text">
              <p>
                Sistemas a medida: dashboards operativos, módulos tipo ERP, apps internas y herramientas para
                terreno. Construidos para tu forma real de trabajar.
              </p>
              <div class="list-block__tags">
                <span class="tag">Sistemas a medida</span>
                <span class="tag">Dashboards y ERPs</span>
              </div>
            </div>
          </article>
          <article class="list-block__item">
            <div class="list-block__title">
              <div class="list-block__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                  ><path
                    d="M3 13h2v8H3v-8zm16-6h2v14h-2V7zm-8 3h2v11h-2v-11zM7 9h2v9H7V9z"
                  ></path></svg
                >
              </div>
              <h3 class="h5">Integración de sistemas</h3>
            </div>
            <div class="list-block__text">
              <p>
                Conectamos ERP, planillas, bases de datos y APIs para que la información circule una sola vez.
                Desaparecen los reingresos y los cuadros que nadie confía.
              </p>
              <div class="list-block__tags">
                <span class="tag">ERP · Excel · APIs</span>
                <span class="tag">Datos unificados</span>
              </div>
            </div>
          </article>
          <article class="list-block__item">
            <div class="list-block__title">
              <div class="list-block__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                  ><path
                    d="M12 2C6.48 2 2 4.69 2 8s4.48 6 10 6 10-2.69 10-6-4.48-6-10-6zm0 10c-4.41 0-8-1.79-8-4s3.59-4 8-4 8 1.79 8 4-3.59 4-8 4zm-8 6c0 2.21 3.58 4 8 4s8-1.79 8-4v-2c0 2.21-3.58 4-8 4s-8-1.79-8-4v2zm0 4c0 2.21 3.58 4 8 4s8-1.79 8-4v-2c0 2.21-3.58 4-8 4s-8-1.79-8-4v2z"
                  ></path></svg
                >
              </div>
              <h3 class="h5">Arquitectura de la información</h3>
            </div>
            <div class="list-block__text">
              <p>
                Modelamos datos, permisos y flujos para que el sistema crezca contigo. Orden hoy significa
                escalabilidad mañana, sin rehacer todo desde cero.
              </p>
              <div class="list-block__tags">
                <span class="tag">Datos ordenados</span>
                <span class="tag">Escalabilidad</span>
              </div>
            </div>
          </article>
        </div>
      </section>

      <section id="folio" class="s-folio target-section">
        <div class="section-header" data-num="03">
          <h3 class="section-header__pretitle">Casos y ejemplos</h3>
          <div class="section-header__grid">
            <h2 class="text-display-1">Soluciones pensadas para tu rubro.</h2>
            <p class="desc">
              Estos son ejemplos típicos de lo que construimos con empresas como la tuya. La implementación se
              adapta a tu proceso real, no al revés.
            </p>
          </div>
        </div>
        <div class="folio-bricks">
          <article class="folio-item">
            <img
              class="folio-item__img"
              src="https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&w=900&q=80"
              alt="Escritorio de contabilidad con facturas, documentos financieros y calculadora"
              width="900"
              height="600"
              loading="lazy"
            />
            <div class="folio-item__meta">
              <p class="folio-item__cat">Contabilidad</p>
              <h3 class="folio-item__title">Conciliaciones, cierres y reportes gerenciales</h3>
            </div>
          </article>
          <article class="folio-item">
            <img
              class="folio-item__img"
              src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=900&q=80"
              alt="Centro de distribución y bodega de pyme"
              width="900"
              height="600"
              loading="lazy"
            />
            <div class="folio-item__meta">
              <p class="folio-item__cat">Logística</p>
              <h3 class="folio-item__title">Seguimiento de rutas y entregas</h3>
            </div>
          </article>
          <article class="folio-item">
            <img
              class="folio-item__img"
              src="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?auto=format&fit=crop&w=900&q=80"
              alt="Obra en construcción y equipo en terreno"
              width="900"
              height="600"
              loading="lazy"
            />
            <div class="folio-item__meta">
              <p class="folio-item__cat">Constructora</p>
              <h3 class="folio-item__title">Gestión de proyectos y avances</h3>
            </div>
          </article>
          <article class="folio-item">
            <img
              class="folio-item__img"
              src="https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&fit=crop&w=900&q=80"
              alt="Planta y operarios revisando proceso con tecnología"
              width="900"
              height="600"
              loading="lazy"
            />
            <div class="folio-item__meta">
              <p class="folio-item__cat">Industria</p>
              <h3 class="folio-item__title">Dashboard de operaciones en vivo</h3>
            </div>
          </article>
        </div>
      </section>

      <section id="beneficios" class="s-benefits target-section">
        <div class="section-header" data-num="04">
          <h3 class="section-header__pretitle">Beneficios</h3>
          <div class="section-header__grid">
            <h2 class="text-display-1">Eficiencia que se nota en la cuenta resultados.</h2>
            <p class="desc">
              Transformación digital con los pies en la planta: menos fricción entre oficina y terreno, más
              claridad para gerencia y equipos.
            </p>
          </div>
        </div>
        <div class="benefits-grid">
          <div class="benefit-card">
            <strong>Ahorro de tiempo</strong>
            <span>Automatizamos lo repetitivo para que tu gente se ocupe de lo que aporta valor.</span>
          </div>
          <div class="benefit-card">
            <strong>Menos errores</strong>
            <span>Un solo origen de datos y validaciones que reducen reprocesos y reclamos.</span>
          </div>
          <div class="benefit-card">
            <strong>Control del negocio</strong>
            <span>Visibilidad de inventarios, producción, costos y cumplimiento en un mismo criterio.</span>
          </div>
          <div class="benefit-card">
            <strong>Decisiones con datos</strong>
            <span>Indicadores confiables para invertir, contratar o ajustar carga con respaldo.</span>
          </div>
        </div>
      </section>

      <section id="proceso" class="s-process target-section">
        <div class="section-header" data-num="05">
          <h3 class="section-header__pretitle">Cómo trabajamos</h3>
          <div class="section-header__grid">
            <h2 class="text-display-1">Un proceso claro, de punta a punta.</h2>
            <p class="desc">
              Partimos por entender tu operación, diseñamos la solución con tu equipo y acompañamos la puesta en
              marcha. Después seguimos disponibles para evolucionar contigo.
            </p>
          </div>
        </div>
        <div class="process-steps">
          <div class="process-step">
            <h3>Diagnóstico</h3>
            <p>Recorremos procesos, entrevistamos actores y mapeamos sistemas y cuellos de botella.</p>
          </div>
          <div class="process-step">
            <h3>Diseño de solución</h3>
            <p>Propuesta concreta: alcance, integraciones, datos y entregables medibles.</p>
          </div>
          <div class="process-step">
            <h3>Desarrollo</h3>
            <p>Iteraciones cortas, entregas visibles y pruebas junto a usuarios reales.</p>
          </div>
          <div class="process-step">
            <h3>Implementación</h3>
            <p>Capacitación, migración controlada y go-live con plan de contingencia.</p>
          </div>
          <div class="process-step">
            <h3>Soporte</h3>
            <p>Mejoras continuas, monitoreo y nuevas integraciones cuando los negocios cambian.</p>
          </div>
        </div>
      </section>

      <footer id="footer" class="s-footer target-section">
        <div class="section-header" data-num="06">
          <h3 class="section-header__pretitle">Contacto</h3>
          <div class="section-header__grid">
            <h2 class="text-display-1">Agenda una reunión. Automatiza tu empresa hoy.</h2>
            <p class="desc">
              Cuéntanos en qué etapa estás: podemos partir con un diagnóstico express sin compromiso. Atendemos
              pymes industriales en la Región del Biobío y proyectos con equipos remotos en Chile.
            </p>
          </div>
        </div>
        <div class="footer-cta">
          <div class="footer-cta__text">
            <p class="desc" style="margin-bottom: 1.2rem;">
              ¿Tienes un proyecto en mente? Escríbenos a
            </p>
            <a class="email-link" href="mailto:hola@pymatica.cl">hola@pymatica.cl</a>
          </div>
          <form class="contact-form" id="cta-form" action="#" method="post">
            <label class="u-screen-reader-text" for="cta-email">Correo electrónico</label>
            <input
              id="cta-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="tu@empresa.cl"
            />
            <button class="btn btn--primary" type="submit">Quiero agendar</button>
          </form>
        </div>
        <div class="footer-bottom">
          <p>
            © {year} Pymatica. Desarrollo de software · Automatización · Integración · Biobío, Chile.
          </p>
          <p>
            <a href="#intro" class="smoothscroll">Volver arriba</a>
          </p>
        </div>
      </footer>
    </section>
  </div>

  <a href="#top" class="go-top smoothscroll" id="go-top" aria-label="Volver arriba">↑</a>

  <script>
    (function () {
      const nav = document.getElementById("site-nav");
      const toggle = document.querySelector(".s-header__menu-toggle");
      const menuLinks = document.querySelectorAll(".s-header__menu-links a");

      function setMenuOpen(open) {
        if (!nav || !toggle) return;
        nav.classList.toggle("is-open", open);
        toggle.classList.toggle("is-clicked", open);
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
        toggle.setAttribute("aria-label", open ? "Cerrar menú" : "Abrir menú");
      }

      if (toggle && nav) {
        toggle.addEventListener("click", function () {
          const open = !nav.classList.contains("is-open");
          setMenuOpen(open);
        });
      }

      menuLinks.forEach(function (link) {
        link.addEventListener("click", function () {
          if (window.matchMedia("(max-width: 1100px)").matches) {
            setMenuOpen(false);
          }
          document.querySelectorAll(".s-header__menu-links li").forEach(function (li) {
            li.classList.remove("current");
          });
          const parentLi = link.closest("li");
          if (parentLi) parentLi.classList.add("current");
        });
      });

      document.querySelectorAll("a.smoothscroll[href^='#']").forEach(function (anchor) {
        anchor.addEventListener("click", function (e) {
          const id = anchor.getAttribute("href");
          if (!id || id === "#") return;
          const el = document.querySelector(id);
          if (el) {
            e.preventDefault();
            el.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        });
      });

      const goTop = document.getElementById("go-top");
      if (goTop) {
        window.addEventListener(
          "scroll",
          function () {
            if (window.scrollY > 500) goTop.classList.add("is-visible");
            else goTop.classList.remove("is-visible");
          },
          { passive: true }
        );
      }

      const form = document.getElementById("cta-form");
      if (form) {
        form.addEventListener("submit", function (e) {
          e.preventDefault();
          const input = form.querySelector('input[type="email"]');
          if (input && input.value) {
            alert("Gracias. Te contactaremos pronto en " + input.value);
          }
        });
      }
    })();
  </script>
</Layout>
