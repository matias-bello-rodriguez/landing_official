---
import fs from "node:fs";
import path from "node:path";
import Layout from "../layouts/Layout.astro";

const title =
  "Pymática — Desarrollo de software";
const year = new Date().getFullYear();

const pubAssets = path.join(process.cwd(), "public", "assets");
const assetExists = (file: string) => fs.existsSync(path.join(pubAssets, file));

const HERO_WIDTHS = [560, 840, 1120, 1400] as const;

/** Hero: columna imagen ~45vw en desktop; móvil ancho contenido */
const HERO_SIZES = "(min-width: 960px) min(45vw, 560px), min(100vw - 3rem, 75rem)";

function buildSrcset(base: string, ext: "avif" | "webp", widths: readonly number[]) {
  return widths.map((w) => `/assets/${base}-${w}.${ext} ${w}w`).join(", ");
}

function hasAllRasterWidths(base: string, widths: readonly number[]) {
  return widths.every((w) => assetExists(`${base}-${w}.avif`));
}

const heroResponsive = hasAllRasterWidths("primera_imagen", HERO_WIDTHS);

const heroAvifSrcset = heroResponsive ? buildSrcset("primera_imagen", "avif", HERO_WIDTHS) : "";
const heroWebpSrcset = heroResponsive ? buildSrcset("primera_imagen", "webp", HERO_WIDTHS) : "";

/** Íconos módulos desde GitHub. Logo servido en /odoo-logo.svg (repo oficial Odoo). */
const odooIconBase = "https://raw.githubusercontent.com/odoo/odoo/17.0/addons";

const odooModules = [
  {
    id: "sale",
    label: "Ventas",
    icon: `${odooIconBase}/sale/static/description/icon.png`,
    title: "Ventas",
    body: "Cotizaciones, órdenes de venta, listas de precios y seguimiento de oportunidades comerciales en un solo flujo. Ideal para estandarizar cómo tu equipo vende y cerrar más rápido.",
  },
  {
    id: "crm",
    label: "CRM",
    icon: `${odooIconBase}/crm/static/description/icon.png`,
    title: "CRM",
    body: "Embudo de oportunidades, actividades, reuniones y pronósticos. Te ayuda a no perder leads y a priorizar en qué clientes enfocar el esfuerzo comercial.",
  },
  {
    id: "account",
    label: "Contabilidad",
    icon: `${odooIconBase}/account/static/description/icon.png`,
    title: "Contabilidad",
    body: "Facturación, conciliación bancaria, libros y reportes financieros alineados a buenas prácticas. Menos planillas paralelas y más trazabilidad contable.",
  },
  {
    id: "stock",
    label: "Inventario",
    icon: `${odooIconBase}/stock/static/description/icon.png`,
    title: "Inventario",
    body: "Ubicaciones, movimientos, trazabilidad por lote/serie y reglas de reabastecimiento. Pensado para bodegas y plantas que necesitan stock confiable en tiempo real.",
  },
  {
    id: "purchase",
    label: "Compras",
    icon: `${odooIconBase}/purchase/static/description/icon.png`,
    title: "Compras",
    body: "Solicitudes de cotización, órdenes de compra y acuerdos con proveedores. Reduce retrabajo entre compras, bodega y contabilidad.",
  },
  {
    id: "project",
    label: "Proyecto",
    icon: `${odooIconBase}/project/static/description/icon.png`,
    title: "Proyecto",
    body: "Tareas, hitos, tableros y seguimiento de horas por proyecto. Sirve para implementaciones, obras o servicios con equipos distribuidos.",
  },
  {
    id: "mrp",
    label: "Fabricación",
    icon: `${odooIconBase}/mrp/static/description/icon.png`,
    title: "Fabricación (MRP)",
    body: "Listas de materiales (BOM), órdenes de fabricación y planificación ligada a inventario. Para pymes que producen y necesitan orden en planta.",
  },
  {
    id: "website",
    label: "Sitio web",
    icon: `${odooIconBase}/website/static/description/icon.png`,
    title: "Sitio web",
    body: "Constructor de páginas, formularios y presencia online integrada con el resto de apps. Menos herramientas sueltas para mantener tu marca.",
  },
  {
    id: "website_sale",
    label: "eCommerce",
    icon: `${odooIconBase}/website_sale/static/description/icon.png`,
    title: "eCommerce",
    body: "Tienda online con carrito, pagos y catálogo conectado al inventario. Útil si vendes B2B o B2C y quieres un solo stock de verdad.",
  },
  {
    id: "hr",
    label: "RR. HH.",
    icon: `${odooIconBase}/hr/static/description/icon.png`,
    title: "Recursos humanos",
    body: "Fichas de empleados, departamentos, contratos y datos centralizados. Base para escalar procesos de people ops sin carpetas dispersas.",
  },
  {
    id: "point_of_sale",
    label: "TPV / POS",
    icon: `${odooIconBase}/point_of_sale/static/description/icon.png`,
    title: "Punto de venta",
    body: "Caja retail con productos, variantes y cobros. Se integra con inventario y facturación según tu configuración.",
  },
  {
    id: "mass_mailing",
    label: "Email marketing",
    icon: `${odooIconBase}/mass_mailing/static/description/icon.png`,
    title: "Email marketing",
    body: "Campañas, listas y plantillas con métricas de apertura y clics. Complementa al CRM para nutrir leads y clientes.",
  },
  {
    id: "calendar",
    label: "Calendario",
    icon: `${odooIconBase}/calendar/static/description/icon.png`,
    title: "Calendario",
    body: "Agenda compartida, reuniones y recordatorios enlazados a contactos y proyectos. Mejora la coordinación entre áreas.",
  },
  {
    id: "contacts",
    label: "Contactos",
    icon: `${odooIconBase}/contacts/static/description/icon.png`,
    title: "Contactos",
    body: "Personas y empresas unificadas: direcciones, etiquetas e historial. Es el directorio maestro que alimenta ventas, compras y facturación.",
  },
  {
    id: "hr_expense",
    label: "Gastos",
    icon: `${odooIconBase}/hr_expense/static/description/icon.png`,
    title: "Gastos",
    body: "Registro de gastos, adjuntos y flujos de aprobación hacia contabilidad. Menos papel y más control sobre rendiciones.",
  },
  {
    id: "hr_holidays",
    label: "Ausencias",
    icon: `${odooIconBase}/hr_holidays/static/description/icon.png`,
    title: "Tiempo libre y ausencias",
    body: "Solicitudes de vacaciones, permisos y balances visibles para el equipo y RR. HH. Transparente y auditable.",
  },
  {
    id: "maintenance",
    label: "Mantenimiento",
    icon: `${odooIconBase}/maintenance/static/description/icon.png`,
    title: "Mantenimiento",
    body: "Órdenes de trabajo en equipos e instalaciones, preventivo y correctivo. Para plantas que dependen de máquinas disponibles.",
  },
  {
    id: "fleet",
    label: "Flota",
    icon: `${odooIconBase}/fleet/static/description/icon.png`,
    title: "Flota",
    body: "Vehículos, contratos, servicios y costos asociados. Ayuda a controlar la operación móvil o logística con activos propios.",
  },
  {
    id: "repair",
    label: "Reparaciones",
    icon: `${odooIconBase}/repair/static/description/icon.png`,
    title: "Reparaciones",
    body: "Gestión de reparaciones de productos devueltos o en garantía, vinculada a inventario y facturación cuando aplica.",
  },
  {
    id: "im_livechat",
    label: "Live chat",
    icon: `${odooIconBase}/im_livechat/static/description/icon.png`,
    title: "Chat en vivo",
    body: "Atención instantánea en tu sitio web con historial y vínculo a oportunidades CRM. Mejora conversión y soporte en la primera visita.",
  },
] as const;

const preloadLcpImage = heroResponsive
  ? `/assets/primera_imagen-${HERO_WIDTHS[HERO_WIDTHS.length - 1]}.avif`
  : assetExists("primera_imagen.svg")
    ? "/assets/primera_imagen.svg"
    : undefined;
const preloadLcpSrcset = heroResponsive ? heroAvifSrcset : undefined;
const preloadLcpSizes = heroResponsive ? HERO_SIZES : undefined;


---

<Layout
  title={title}
  preloadLcpImage={preloadLcpImage}
  preloadLcpSrcset={preloadLcpSrcset}
  preloadLcpSizes={preloadLcpSizes}
>
  <a class="skip-link" href="#content">Saltar al contenido</a>

  <!-- Mobile nav overlay -->
  <div class="nav-overlay" id="nav-overlay"></div>

  <div class="s-pagewrap" id="top">
    <!-- ════════════════════════════════════════
         NAVBAR
         ════════════════════════════════════════ -->
    <header class="s-header" id="site-header">
      <div class="s-header__inner">
        <a class="s-header__brand smoothscroll" href="#intro">Pymatica<span class="s-header__brand-dot">.</span></a>
        <button
          type="button"
          class="s-header__menu-toggle"
          aria-expanded="false"
          aria-controls="site-nav"
          aria-label="Abrir menú"
        >
          <span></span>
        </button>
        <nav id="site-nav" class="s-header__nav" aria-label="Principal">
          <ul class="s-header__menu-links">
            <li class="current"><a href="#intro" class="smoothscroll">Inicio</a></li>
            <li><a href="#about" class="smoothscroll">Enfoque</a></li>
            <li><a href="#services" class="smoothscroll">Servicios</a></li>
            <li><a href="#folio" class="smoothscroll">Casos</a></li>
            <li><a href="#beneficios" class="smoothscroll">Beneficios</a></li>
            <li><a href="#proceso" class="smoothscroll">Proceso</a></li>
            <li><a href="#footer" class="smoothscroll">Contacto</a></li>
          </ul>
          <ul class="s-header__social">
            <li>
              <a href="https://www.linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                <svg viewBox="0 0 24 24" aria-hidden="true"
                  ><path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  ></path></svg
                >
                <span class="u-screen-reader-text">LinkedIn</span>
              </a>
            </li>
            <li>
              <a href="https://www.instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <svg viewBox="0 0 24 24" aria-hidden="true"
                  ><path
                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                  ></path></svg
                >
                <span class="u-screen-reader-text">Instagram</span>
              </a>
            </li>
          </ul>
          <a class="s-header__menu-button smoothscroll" href="#footer">Agendar reunión</a>
        </nav>
      </div>
    </header>

    <main id="content" class="s-content">

      <!-- ════════════════════════════════════════
           HERO SECTION
           ════════════════════════════════════════ -->
      <section id="intro" class="s-intro target-section">
        <!-- Animated grid canvas background -->
        <canvas class="hero-grid-canvas" id="hero-canvas" aria-hidden="true"></canvas>

        <div class="s-intro__inner">
          <div class="s-intro__text">
            <h1 class="s-intro__title" id="hero-title">
              <span class="word">Automatizamos </span>
              <span class="word">los </span>
              <span class="word">procesos </span>
              <span class="word">de </span>
              <span class="word">tu </span>
              <span class="word">empresa</span>
            </h1>
            <p class="s-intro__lead">
              Software a medida, integración de sistemas y arquitectura de la información.
            </p>
            <div class="s-intro__actions">
              <a class="btn btn--primary smoothscroll" href="#footer">Solicitar diagnóstico</a>
              <a class="btn btn--ghost smoothscroll" href="#services">Ver soluciones</a>
            </div>
            <!-- Animated counters -->
            <div class="hero-stats">
              <div class="hero-stat">
                <span class="hero-stat__number" data-count="10">0</span>
                <span class="hero-stat__label">Proyectos</span>
              </div>
              <div class="hero-stat">
                <span class="hero-stat__number" data-count="5">0</span>
                <span class="hero-stat__label">Años</span>
              </div>
            </div>
          </div>

          <!-- Parallax: srcset tras npm run assets:images; SVG como respaldo -->
          <figure class="s-intro__figure" id="hero-figure">
            <picture>
              {heroResponsive && (
                <source
                  type="image/avif"
                  srcset={heroAvifSrcset}
                  sizes={HERO_SIZES}
                />
              )}
              {heroResponsive && (
                <source
                  type="image/webp"
                  srcset={heroWebpSrcset}
                  sizes={HERO_SIZES}
                />
              )}
              <img
                src="/assets/primera_imagen.svg"
                alt="Desarrollador trabajando en un portátil con código en pantalla"
                width="1400"
                height="1050"
                sizes={heroResponsive ? HERO_SIZES : undefined}
                fetchpriority="high"
                decoding="sync"
              />
            </picture>
          </figure>
        </div>
        <div class="s-intro__scroll">
          <a href="#about" class="smoothscroll s-intro__scroll-link"><span>Descubre más</span></a>
        </div>
      </section>

      <!-- ════════════════════════════════════════
           ABOUT / PROBLEMA Y SOLUCIÓN
           ════════════════════════════════════════ -->
      <section id="about" class="s-about target-section">
        <div class="section-header reveal" data-num="01">
          <p class="section-header__pretitle">Problema y solución</p>
          <div class="section-header__grid">
            <h2 class="text-display-1">
              Cuando Excel, el papel y los sistemas viejos no alcanzan.
            </h2>
            <p class="desc">
              Las pymes pierden horas en tareas repetitivas, duplican datos y deciden a ciegas. Nosotros
              ordenamos la información, conectamos lo que ya tienes y automatizamos lo que frena tu operación.
            </p>
          </div>
        </div>
        <div class="ps-grid reveal-group">
          <div class="ps-card reveal">
            <h3>Lo que duele hoy</h3>
            <ul class="ps-list">
              <li>Procesos manuales y lentos</li>
              <li>Excel desordenado y versiones distintas</li>
              <li>Sistemas desconectados (ERP, bodega, contabilidad)</li>
              <li>Pérdida de tiempo y errores costosos</li>
            </ul>
          </div>
          <div class="ps-card ps-card--solution reveal">
            <h3>Cómo lo resolvemos</h3>
            <ul class="ps-list">
              <li>Automatización de flujos y alertas</li>
              <li>Integración entre plataformas y APIs</li>
              <li>Software centralizado y trazable</li>
              <li>Menos fricción, más control operativo</li>
            </ul>
          </div>
        </div>
        <div class="about-odoo reveal reveal--scale">
          <div class="about-odoo__inner">
            <header class="about-odoo__header">
              <div class="about-odoo__logo-wrap">
                <img
                  class="about-odoo__logo"
                  src="/odoo-logo.svg"
                  alt="Odoo"
                  width="621"
                  height="196"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <p class="about-odoo__intro">
                Suite de aplicaciones de negocio de código abierto. Toca un módulo para ver en qué ayuda a tu operación.
              </p>
            </header>
            <ul class="about-odoo__grid" role="list">
              {odooModules.map((m) => (
                <li>
                  <button
                    type="button"
                    class="about-odoo__tile"
                    data-module={m.id}
                    aria-haspopup="dialog"
                    aria-controls="odoo-module-dialog"
                  >
                    <span class="about-odoo__tile-icon">
                      <img
                        src={m.icon}
                        alt=""
                        width="56"
                        height="56"
                        loading="lazy"
                        decoding="async"
                        referrerpolicy="no-referrer"
                      />
                    </span>
                    <span class="about-odoo__tile-label">{m.label}</span>
                  </button>
                </li>
              ))}
            </ul>
          </div>
        </div>

        <dialog id="odoo-module-dialog" class="odoo-modal" aria-labelledby="odoo-modal-title">
          <div class="odoo-modal__panel">
            <button type="button" class="odoo-modal__close" aria-label="Cerrar ventana">
              ×
            </button>
            <img class="odoo-modal__icon" src="" alt="" width="72" height="72" hidden />
            <h2 id="odoo-modal-title" class="odoo-modal__title"></h2>
            <div class="odoo-modal__body"></div>
          </div>
        </dialog>
        <script
          type="application/json"
          id="odoo-modules-json"
          set:html={JSON.stringify(odooModules)}
        />
      </section>

      <!-- ════════════════════════════════════════
           SERVICES / SERVICIOS
           ════════════════════════════════════════ -->
      <section id="services" class="s-services target-section">
        <div class="section-header reveal" data-num="02">
          <p class="section-header__pretitle">Qué hacemos</p>
          <div class="section-header__grid">
            <h2 class="text-display-1">Cuatro pilares para transformar tu operación.</h2>
            <p class="desc">
              Trabajamos con un lenguaje claro, sin tecnicismos innecesarios. Cada proyecto apunta a resultados
              medibles: tiempo recuperado, errores evitados y decisiones con datos confiables.
            </p>
          </div>
        </div>
        <div class="services-list reveal-group">
          <article class="list-block__item reveal" data-tilt>
            <div class="list-block__title">
              <div class="list-block__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                  ><path
                    d="M12 2L4 5v6.09c0 5.05 3.41 9.76 8 10.91 4.59-1.15 8-5.86 8-10.91V5l-8-3zm6 9c0 4.52-2.98 8.69-7 9.93-4.02-1.24-7-5.41-7-9.93V6.3l7-2.11 7 2.11V11zm-9.5-2L12 11l3.5-2L12 7 8.5 9z"
                  ></path></svg
                >
              </div>
              <h3 class="h5">Automatización de procesos</h3>
            </div>
            <div class="list-block__text">
              <p>
                Flujos automáticos entre áreas: aprobaciones, notificaciones, cargas de datos recurrentes. Menos
                tareas manuales, más consistencia en planta y oficina.
              </p>
              <div class="list-block__tags">
                <span class="tag">Flujos automáticos</span>
                <span class="tag">Menos tareas manuales</span>
              </div>
            </div>
          </article>
          <article class="list-block__item reveal" data-tilt>
            <div class="list-block__title">
              <div class="list-block__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                  ><path
                    d="M9.4 16.6L4.8 12l4.6-4.6L8 6l-6 6 6 6 1.4-1.4zm5.2 0L19.2 12l-4.6-4.6L16 6l6 6-6 6-1.4-1.4z"
                  ></path></svg
                >
              </div>
              <h3 class="h5">Desarrollo de software</h3>
            </div>
            <div class="list-block__text">
              <p>
                Sistemas a medida: dashboards operativos, módulos tipo ERP, apps internas y herramientas para
                terreno. Construidos para tu forma real de trabajar.
              </p>
              <div class="list-block__tags">
                <span class="tag">Sistemas a medida</span>
                <span class="tag">Dashboards y ERPs</span>
              </div>
            </div>
          </article>
          <article class="list-block__item reveal" data-tilt>
            <div class="list-block__title">
              <div class="list-block__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                  ><path
                    d="M3 13h2v8H3v-8zm16-6h2v14h-2V7zm-8 3h2v11h-2v-11zM7 9h2v9H7V9z"
                  ></path></svg
                >
              </div>
              <h3 class="h5">Integración de sistemas</h3>
            </div>
            <div class="list-block__text">
              <p>
                Conectamos ERP, planillas, bases de datos y APIs para que la información circule una sola vez.
                Desaparecen los reingresos y los cuadros que nadie confía.
              </p>
              <div class="list-block__tags">
                <span class="tag">ERP · Excel · APIs</span>
                <span class="tag">Datos unificados</span>
              </div>
            </div>
          </article>
          <article class="list-block__item reveal" data-tilt>
            <div class="list-block__title">
              <div class="list-block__icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                  ><path
