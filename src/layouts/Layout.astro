---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  /** Ruta pública del recurso LCP del hero (p. ej. /assets/primera_imagen.svg) */
  preloadLcpImage?: string;
}

const {
  title,
  description = "Pymatica: desarrollo de software, automatización de procesos e integración de sistemas para pymes industriales en la Región del Biobío, Chile.",
  preloadLcpImage,
} = Astro.props;

function preloadImageType(href: string): string | undefined {
  const lower = href.split("?")[0].toLowerCase();
  if (lower.endsWith(".svg")) return "image/svg+xml";
  if (lower.endsWith(".avif")) return "image/avif";
  if (lower.endsWith(".webp")) return "image/webp";
  if (lower.endsWith(".png")) return "image/png";
  if (lower.endsWith(".jpg") || lower.endsWith(".jpeg")) return "image/jpeg";
  return undefined;
}

const preloadLcpType = preloadLcpImage ? preloadImageType(preloadLcpImage) : undefined;
---

<!doctype html>
<html lang="es" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <meta name="theme-color" content="#F8FAFC" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#020817" media="(prefers-color-scheme: dark)" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {
      preloadLcpImage ? (
        <link
          rel="preload"
          href={preloadLcpImage}
          as="image"
          {...(preloadLcpType ? { type: preloadLcpType } : {})}
        />
      ) : null
    }
    <!-- Theme + JS class — runs before paint to prevent FOUC -->
    <script is:inline>
      (function () {
        var d = document.documentElement;
        d.classList.remove("no-js");
        d.classList.add("js");
        var saved = localStorage.getItem("pymatica-theme");
        if (saved === "dark" || saved === "light") {
          d.setAttribute("data-theme", saved);
        } else {
          d.setAttribute(
            "data-theme",
            window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"
          );
        }
      })();
    </script>
  </head>
  <body id="top" class="site">
    <slot />
  </body>
</html>
