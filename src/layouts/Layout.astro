---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Pymatica: desarrollo de software, automatización de procesos e integración de sistemas para pymes industriales en la Región del Biobío, Chile.",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <!-- Theme + JS class — runs before paint to prevent FOUC -->
    <script is:inline>
      (function() {
        var d = document.documentElement;
        d.classList.remove("no-js");
        d.classList.add("js");
        /* Theme: check localStorage, then system preference, default light */
        var saved = localStorage.getItem("pymatica-theme");
        if (saved === "dark" || saved === "light") {
          d.setAttribute("data-theme", saved);
        } else {
          d.setAttribute("data-theme",
            window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light"
          );
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body id="top" class="site">
    <slot />
  </body>
</html>
